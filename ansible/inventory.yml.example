# Скопируйте в inventory.yml и подставьте IP ВМ из вывода Terraform:
#   terraform -chdir=terraform output -raw vm_public_ip

all:
  children:
    vm:
      hosts:
        lab2:
          ansible_host: 0.0.0.0   # Замените на IP из: terraform -chdir=../terraform output -raw vm_public_ip
          ansible_user: ubuntu
          ansible_ssh_private_key_file: ~/.ssh/id_rsa
